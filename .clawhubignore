# Whitelist approach: ignore everything, then unignore what npm publishes
# (mirrors the "files" field in package.json plus README/LICENSE/manifests).
*

# Required manifests
!package.json
!openclaw.plugin.json
!README.md
!LICENSE

# Compiled output
!dist/
!dist/**

# Server: include the whole runtime tree. The arm64 wheel must NOT ship here
# (24 MB > ClawHub's 20 MB limit). NOTE: clawhub CLI 0.12.3 does not honour
# exclude/subtract patterns under a re-included dir, so the wheel is kept out of
# the upload by removing it from disk before `clawhub package publish` (see
# scripts/publish-clawhub.sh), not by an ignore rule. server-manager.ts
# downloads the wheel from GitHub Releases on first start.
!server/
!server/**
server/__pycache__/
server/__pycache__/**
server/.venv/
server/.venv/**
server/.pytest_cache/
server/.pytest_cache/**

# Top-level runtime config
!docker-compose.yml
!config.yaml
!.env.example

# Hard excludes (defence in depth — never publish secrets or local state)
.env
.env.*
!.env.example
