# Whitelist approach: ignore everything, then unignore what npm publishes
# (mirrors the "files" field in package.json plus README/LICENSE/manifests).
*

# Required manifests
!package.json
!openclaw.plugin.json
!README.md
!LICENSE

# Compiled output
!dist/
!dist/**

# Server: only the runtime files. The arm64 wheel is NOT shipped via ClawHub
# (24 MB > ClawHub's 20 MB upload limit). server-manager.ts downloads it from
# GitHub Releases on first start when the install dir has no bundled wheels.
!server/
server/*
!server/Dockerfile
!server/main.py
!server/pyproject.toml
!server/uv.lock
!server/requirements.txt

# Top-level runtime config
!docker-compose.yml
!config.yaml
!.env.example

# Hard excludes (defence in depth — never publish secrets or local state)
.env
.env.*
!.env.example
