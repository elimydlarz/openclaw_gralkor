# Whitelist approach: ignore everything, then unignore what npm publishes
# (mirrors the "files" field in package.json plus README/LICENSE/manifests).
*

# Required manifests
!package.json
!openclaw.plugin.json
!README.md
!LICENSE

# Compiled output
!dist/
!dist/**

# Server: include the whole runtime tree but exclude the arm64 wheel
# (24 MB > ClawHub's 20 MB upload limit). server-manager.ts downloads the
# wheel from GitHub Releases on first start when the install dir has no
# bundled wheels.
!server/
!server/**
server/wheels/
server/wheels/**
server/__pycache__/
server/__pycache__/**
server/.venv/
server/.venv/**
server/.pytest_cache/
server/.pytest_cache/**

# Top-level runtime config
!docker-compose.yml
!config.yaml
!.env.example

# Hard excludes (defence in depth — never publish secrets or local state)
.env
.env.*
!.env.example
