{
  "id": "openclaw-gralkor",
  "kind": "memory",
  "name": "Gralkor Memory (OpenClaw)",
  "description": "Persistent, temporally-aware memory via Graphiti knowledge graphs and FalkorDB",
  "configSchema": {
    "type": "object",
    "properties": {
      "autoCapture": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Automatically capture conversations into the graph"
          }
        }
      },
      "autoRecall": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true,
            "description": "Automatically recall relevant context before agent runs"
          },
          "maxResults": {
            "type": "number",
            "default": 10,
            "description": "Maximum number of facts to inject as context"
          }
        }
      },
      "search": {
        "type": "object",
        "properties": {
          "maxResults": {
            "type": "number",
            "default": 20,
            "description": "Maximum number of facts returned by the memory_search tool"
          },
          "maxEntityResults": {
            "type": "number",
            "default": 10,
            "description": "Maximum number of entity summaries returned by the memory_search tool"
          }
        }
      },
      "llm": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "LLM provider for knowledge extraction (openai, anthropic, gemini, groq)"
          },
          "model": {
            "type": "string",
            "description": "LLM model name (e.g. gpt-4.1-mini, gemini-2.0-flash)"
          }
        }
      },
      "embedder": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "description": "Embedding provider (openai, gemini)"
          },
          "model": {
            "type": "string",
            "description": "Embedding model name (e.g. text-embedding-3-small)"
          }
        }
      },
      "test": {
        "type": "boolean",
        "default": false,
        "description": "Enable test mode — logs full episode bodies and search results for debugging"
      },
      "googleApiKey": {
        "type": [
          "string",
          "object",
          "null"
        ],
        "description": "Google API key for Gemini LLM and embeddings"
      },
      "openaiApiKey": {
        "type": [
          "string",
          "object",
          "null"
        ],
        "description": "OpenAI API key; also needed for embeddings with Anthropic/Groq providers"
      },
      "anthropicApiKey": {
        "type": [
          "string",
          "object",
          "null"
        ],
        "description": "Anthropic API key for Claude-based LLM extraction"
      },
      "groqApiKey": {
        "type": [
          "string",
          "object",
          "null"
        ],
        "description": "Groq API key for Groq-hosted LLM extraction"
      }
    }
  },
  "tools": [
    "memory_search",
    "memory_add",
    "memory_build_indices",
    "memory_build_communities"
  ],
  "uiHints": {
    "autoCapture.enabled": {
      "label": "Auto-capture conversations"
    },
    "autoRecall.enabled": {
      "label": "Auto-recall context"
    },
    "autoRecall.maxResults": {
      "label": "Max auto-recall results"
    },
    "llm.provider": {
      "label": "LLM provider"
    },
    "llm.model": {
      "label": "LLM model"
    },
    "embedder.provider": {
      "label": "Embedding provider"
    },
    "embedder.model": {
      "label": "Embedding model"
    },
    "test": {
      "label": "Test mode (verbose logging)"
    },
    "googleApiKey": {
      "label": "Google API key"
    },
    "openaiApiKey": {
      "label": "OpenAI API key"
    },
    "anthropicApiKey": {
      "label": "Anthropic API key"
    },
    "groqApiKey": {
      "label": "Groq API key"
    }
  },
  "version": "1.1.2"
}
